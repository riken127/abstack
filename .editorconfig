root = true

[CMakeLists.txt]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{h,hpp,hxx,c,cc,cpp,cxx}]
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 100
trim_trailing_whitespace = true

[*.{json,json5,proto}]
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
indent_style = space
insert_final_newline = true

[*.{yaml,yml}]
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
